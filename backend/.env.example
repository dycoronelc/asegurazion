# CORS: dominio(s) del frontend, separados por coma (Railway: referencia al otro servicio)
# CORS_ORIGINS=https://${{web.RAILWAY_PUBLIC_DOMAIN}},http://localhost:5173

# Persistencia CRM (al añadir ORM; el informe mencionaba PostgreSQL/Supabase; MySQL es válido)
# DATABASE_URL=mysql+pymysql://usuario:clave@localhost:3306/asegurazion
# DATABASE_URL=postgresql+psycopg://usuario:clave@host:5432/postgres

# MAPFRE (Panamá) — OAuth password grant; usuario y clave en texto plano (el backend los codifica a Base64 al pedir el token)
MAPFRE_TOKEN_URL=https://app1.mapfre.com.pa/panama/webapi/token
MAPFRE_API_BASE=https://app1.mapfre.com.pa/panama/webapi
MAPFRE_USERNAME=
MAPFRE_PASSWORD=
# true = usuario/clave ya están en Base64 en variables (evita doble codificación)
MAPFRE_CREDENTIALS_ALREADY_BASE64=false
MAPFRE_CLIENT_ID=
MAPFRE_CLIENT_SECRET=
# Header enviado al token MAPFRE (normalmente PASSWORD)
MAPFRE_TIPO_VALIDACION=PASSWORD

# SURA — OAuth client credentials + usuario corredor (según documentación)
SURA_OAUTH_URL=https://iservice01.segurossura.com.pa/TokenService/resources/tokenservice
SURA_CLIENT_ID=
SURA_CLIENT_SECRET=
SURA_CORREDOR_USER=
SURA_CORREDOR_PASSWORD=
SURA_API_BASE=https://iservice01.segurossura.com.pa

# Internacional de Seguros — SOAP descargas.asmx
ISEGUROS_WSDL=https://www.iseguros.com/corredor_web2/descargas.asmx?wsdl
ISEGUROS_WS_KEY=

# Óptima — SOAP cartera (ajustar WSDL si tu ambiente usa otra URL)
OPTIMA_CARTERA_WSDL=https://www1.optinet.com.pa/WsCarteraCorredor-WebServices-context-root/WebServices_TopLinkPlSqlProviderService?WSDL
OPTIMA_CORREDOR_CODE=
